{
  "manifest_version": 3,
  "name": "Kick Stream Control",
  "version": "1.0.2",
  "description": "Control Kick.com streams with mouse buttons: left click toggles play/pause, right-click + scroll adjusts volume, and middle click toggles mute. Also displays volume percentage overlay.",
  "icons": {
    "48": "icons/kick_icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://kick.com/*", "*://*.kick.com/*"],
      "js": [
        "scripts/config.js",
        "scripts/core.js",
        "scripts/dom.js",
        "scripts/audio.js",
        "scripts/video.js",
        "scripts/bitrate.js",
        "scripts/ui-overlays.js",
        "scripts/control-panel.js",
        "scripts/controls-visibility.js",
        "scripts/player-controls.js",
        "scripts/safety.js",
        "scripts/kvw.js",
        "scripts/init.js"
      ],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "KickScroll"
  },
  "web_accessible_resources": [
    {
      "resources": ["scripts/pip-inject.js"],
      "matches": ["*://kick.com/*", "*://*.kick.com/*"]
    }
  ],
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "*://kick.com/*",
    "*://*.kick.com/*"
  ]
}
